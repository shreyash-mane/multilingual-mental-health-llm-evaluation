{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Nemotron Zero-Shot\n",
        "\n",
        "Expected input columns:\n",
        "- `PromptID`\n",
        "- `English`\n",
        "- `Hindi`\n",
        "\n",
        "Output columns created:\n",
        "- `EN_ZeroShot_Prompt`\n",
        "- `EN_ZeroShot_Response`\n",
        "- `HI_ZeroShot_Prompt`\n",
        "- `HI_ZeroShot_Response`\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "!pip -q install transformers accelerate sentencepiece openpyxl pandas"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "import pandas as pd\n",
        "import torch\n",
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n",
        "\n",
        
        "MODEL_NAME = \"nvidia/Nemotron-4-Mini-Hindi-4B-Base\"\n",
        "\n",
        "INPUT_XLSX = \"/content/Dataset_550_Nemotron.xlsx\"\n",
        "OUTPUT_XLSX = \"/content/nemotron_zeroshot_output.xlsx\"\n",
        "PROGRESS_XLSX = \"/content/nemotron_zeroshot_progress.xlsx\"\n"
        "\n",
        "ID_COL = \"PromptID\"\n",
        "EN_COL = \"English\"\n",
        "HI_COL = \"Hindi\"\n",
        "\n",
        "MAX_NEW_TOKENS = 180\n",
        "TEMPERATURE = 0.7\n",
        "TOP_P = 0.9\n",
        "TOP_K = 50\n",
        "DO_SAMPLE = True\n",
        "SAVE_EVERY = 10\n",
        "# ==================\n",
        "\n",
        "assert os.path.exists(INPUT_XLSX), f\"Input file not found: {INPUT_XLSX}\""
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def build_en_prompt(text: str) -> str:\n",
        "    return f\"User: {str(text).strip()}\"\n",
        "\n",
        "def build_hi_prompt(text: str) -> str:\n",
        "    return f\"यूज़र: {str(text).strip()}\"\n",
        "\n",
        "def clean_text(x):\n",
        "    if pd.isna(x):\n",
        "        return \"\"\n",
        "    return str(x).strip()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "print(\"Using device:\", device)\n",
        "\n",
        "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
        "model = AutoModelForCausalLM.from_pretrained(\n",
        "    MODEL_NAME,\n",
        "    torch_dtype=torch.float16 if device == \"cuda\" else torch.float32,\n",
        "    device_map=\"auto\" if device == \"cuda\" else None\n",
        ")\n",
        "\n",
        "if tokenizer.pad_token is None:\n",
        "    tokenizer.pad_token = tokenizer.eos_token\n",
        "\n",
        "model.eval()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "df = pd.read_excel(INPUT_XLSX)\n",
        "df.columns = [c.strip() for c in df.columns]\n",
        "\n",
        "needed = {ID_COL, EN_COL, HI_COL}\n",
        "missing = needed - set(df.columns)\n",
        "if missing:\n",
        "    raise ValueError(f\"Missing columns: {missing}. Found: {list(df.columns)}\")\n",
        "\n",
        "df[EN_COL] = df[EN_COL].apply(clean_text)\n",
        "df[HI_COL] = df[HI_COL].apply(clean_text)\n",
        "\n",
        "df[\"EN_ZeroShot_Prompt\"] = df[EN_COL].apply(build_en_prompt)\n",
        "df[\"HI_ZeroShot_Prompt\"] = df[HI_COL].apply(build_hi_prompt)\n",
        "\n",
        "if \"EN_ZeroShot_Response\" not in df.columns:\n",
        "    df[\"EN_ZeroShot_Response\"] = \"\"\n",
        "if \"HI_ZeroShot_Response\" not in df.columns:\n",
        "    df[\"HI_ZeroShot_Response\"] = \"\"\n",
        "\n",
        "df.head()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def generate_response(prompt: str) -> str:\n",
        "    inputs = tokenizer(\n",
        "        prompt,\n",
        "        return_tensors=\"pt\",\n",
        "        truncation=True,\n",
        "        max_length=1024\n",
        "    )\n",
        "\n",
        "    inputs = {k: v.to(model.device) for k, v in inputs.items()}\n",
        "\n",
        "    with torch.no_grad():\n",
        "        output_ids = model.generate(\n",
        "            **inputs,\n",
        "            max_new_tokens=MAX_NEW_TOKENS,\n",
        "            do_sample=DO_SAMPLE,\n",
        "            temperature=TEMPERATURE,\n",
        "            top_p=TOP_P,\n",
        "            top_k=TOP_K,\n",
        "            eos_token_id=tokenizer.eos_token_id,\n",
        "            pad_token_id=tokenizer.pad_token_id,\n",
        "        )\n",
        "\n",
        "    input_len = inputs[\"input_ids\"].shape[1]\n",
        "    new_tokens = output_ids[0][input_len:]\n",
        "    text = tokenizer.decode(new_tokens, skip_special_tokens=True).strip()\n",
        "    return text if text else \"[EMPTY_OUTPUT]\""
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Run generation\n",
        "for i in range(len(df)):\n",
        "    en_done = clean_text(df.at[i, \"EN_ZeroShot_Response\"])\n",
        "    hi_done = clean_text(df.at[i, \"HI_ZeroShot_Response\"])\n",
        "\n",
        "    if not en_done:\n",
        "        try:\n",
        "            df.at[i, \"EN_ZeroShot_Response\"] = generate_response(df.at[i, \"EN_ZeroShot_Prompt\"])\n",
        "        except Exception as e:\n",
        "            df.at[i, \"EN_ZeroShot_Response\"] = f\"[ERROR] {e}\"\n",
        "\n",
        "    if not hi_done:\n",
        "        try:\n",
        "            df.at[i, \"HI_ZeroShot_Response\"] = generate_response(df.at[i, \"HI_ZeroShot_Prompt\"])\n",
        "        except Exception as e:\n",
        "            df.at[i, \"HI_ZeroShot_Response\"] = f\"[ERROR] {e}\"\n",
        "\n",
        "    if (i + 1) % SAVE_EVERY == 0:\n",
        "        df.to_excel(PROGRESS_XLSX, index=False)\n",
        "        print(f\"Saved progress: {i+1}/{len(df)}\")\n",
        "\n",
        "df.to_excel(OUTPUT_XLSX, index=False)\n",
        "print(\"Done. Final file saved to:\", OUTPUT_XLSX)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Optional: download final output in Colab\n",
        "from google.colab import files\n",
        "files.download(OUTPUT_XLSX)"
      ]
    }
  ],
